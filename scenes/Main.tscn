margin_right = 516.0
margin_bottom = 48.0
text = "Welcome To Rabbit Hunt Trainer"

[node name="WelcomeBody" type="Label" parent="HUD/Root/WelcomeModal/WelcomePanel"]
margin_left = 24.0
margin_top = 58.0
margin_right = 516.0
margin_bottom = 250.0
text = "Mission: find the real conversation and ignore the educational content.\n\nHow to play:\n- Move with WASD and point the DF antenna with the mouse.\n- Tune the DF receiver by typing a frequency, dragging the slider, or clicking the waterfall.\n- Listen for the clearest copy on the real conversation while using the scanner as a search tool.\n- Press Space from two or more locations to capture bearings.\n- Click the map to place your estimated fix, then press Submit.\n\nHelpful controls:\n- F starts the scanner\n- Unlock drops the current scanner lock\n- C toggles clean monitor"
autowrap = true

[node name="WelcomeHint" type="Label" parent="HUD/Root/WelcomeModal/WelcomePanel"]
margin_left = 24.0
margin_top = 258.0
margin_right = 516.0
margin_bottom = 280.0
text = "Start the hunt when you're ready."
align = 1

