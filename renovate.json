{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "^\\.github/workflows/ci\\.yml$",
        "^run_demo\\.sh$",
        "^scripts/build_exports\\.sh$"
      ],
      "matchStrings": [
        "renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) versioning=(?<versioning>\\S+)\\s+GODOT_RELEASE[=:\\\"]+\\s*\\\"?(?<currentValue>[^\\\"\\n]+)\\\"?"
      ]
    }
  ]
}
